
{% extends 'base.html.twig' %}

{% block title %}{{ category.name }} - Our Store{% endblock %}
{% block nav_categories %}active{% endblock %}

{% block body %}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path('app_home') }}">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a href="{{ path('app_browse_categories') }}">Categories</a>
            </li>
            <li class="breadcrumb-item active">{{ category.name }}</li>
        </ol>
    </nav>
</div>

<div class="container my-4">
    <div class="p-5 mb-4 bg-{{ category.badgeColor ?? 'primary' }} bg-gradient text-white rounded-3">
        <div class="container-fluid py-3">
            <h1 class="display-4 fw-bold">{{ category.name }}</h1>
            <p class="col-md-8 fs-5">{{ category.description }}</p>
            <span class="badge bg-light text-dark fs-6">
                {{ products|length }} Products Available
            </span>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row row-cols-1 row-cols-md-3 g-4">
        {% for product in products %}
        <div class="col">
            <div class="card h-100">
                {% if product.image %}
                <img src="/images/{{ product.image }}" class="card-img-top" alt="{{ product.name }}">
                {% else %}
                <img src="https://placehold.co/400x300?text={{ product.name|url_encode }}"
                     class="card-img-top" alt="{{ product.name }}">
                {% endif %}
                <div class="card-body">
                    <span class="badge bg-{{ category.badgeColor ?? 'primary' }} mb-2">
                        {{ category.name }}
                    </span>
                    <h5 class="card-title">{{ product.name }}</h5>
                    <p class="card-text fw-bold text-success">${{ product.price }}</p>
                    <a href="{{ path('app_product_details', {id: product.id}) }}"
                       class="btn btn-outline-{{ category.badgeColor ?? 'primary' }}">
                        View Details
                    </a>
                </div>
            </div>
        </div>
        {% else %}
        <div class="col-12">
            <div class="alert alert-info">Aucun produit dans cette catégorie.</div>
        </div>
        {% endfor %}
    </div>
</div>

{% endblock %}


