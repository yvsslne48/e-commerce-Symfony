<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - Our Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <!-- Header -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="home.html">Our Store</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="home.html">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="index.html">Products</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="cart.html">Cart</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="profile.html">Profile</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <div class="bg-primary bg-gradient text-white py-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h1 class="display-3 fw-bold mb-4">Welcome to Our Store</h1>
                    <p class="lead mb-4">Discover amazing products across all categories. Quality items at unbeatable prices.</p>
                    <a href="index.html" class="btn btn-light btn-lg me-2">Shop Now</a>
                    <a href="#categories" class="btn btn-outline-light btn-lg">Browse Categories</a>
                </div>
                <div class="col-lg-6 text-center">
                    <img src="https://via.placeholder.com/500x400" class="img-fluid rounded" alt="Shopping">
                </div>
            </div>
        </div>
    </div>

    <!-- Categories Section -->
    <div class="container my-5" id="categories">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Shop by Category</h2>
            <p class="text-muted">Explore our wide range of products organized by category</p>
        </div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            <!-- Category 1: Electronics -->
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <span class="badge bg-primary mb-2">12 Products</span>
                        <h4 class="card-title">Electronics</h4>
                        <p class="card-text text-muted">Headphones, speakers, gadgets and more</p>
                        <a href="categories.html?category=electronics" class="btn btn-outline-primary">Browse Electronics</a>
                    </div>
                </div>
            </div>

            <!-- Category 2: Fashion -->
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <span class="badge bg-warning mb-2">18 Products</span>
                        <h4 class="card-title">Fashion</h4>
                        <p class="card-text text-muted">Clothing, accessories and footwear</p>
                        <a href="categories.html?category=fashion" class="btn btn-outline-warning">Browse Fashion</a>
                    </div>
                </div>
            </div>

            <!-- Category 3: Home & Garden -->
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <span class="badge bg-success mb-2">15 Products</span>
                        <h4 class="card-title">Home & Garden</h4>
                        <p class="card-text text-muted">Furniture, decor and gardening tools</p>
                        <a href="categories.html?category=home-garden" class="btn btn-outline-success">Browse Home & Garden</a>
                    </div>
                </div>
            </div>

            <!-- Category 4: Sports & Fitness -->
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <span class="badge bg-info mb-2">10 Products</span>
                        <h4 class="card-title">Sports & Fitness</h4>
                        <p class="card-text text-muted">Workout gear, yoga mats and equipment</p>
                        <a href="categories.html?category=sports" class="btn btn-outline-info">Browse Sports</a>
                    </div>
                </div>
            </div>

            <!-- Category 5: Books -->
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <span class="badge bg-danger mb-2">8 Products</span>
                        <h4 class="card-title">Books</h4>
                        <p class="card-text text-muted">Fiction, non-fiction and educational</p>
                        <a href="categories.html?category=books" class="btn btn-outline-danger">Browse Books</a>
                    </div>
                </div>
            </div>

            <!-- Category 6: Beauty & Health -->
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <span class="badge bg-secondary mb-2">14 Products</span>
                        <h4 class="card-title">Beauty & Health</h4>
                        <p class="card-text text-muted">Skincare, cosmetics and wellness</p>
                        <a href="categories.html?category=beauty" class="btn btn-outline-secondary">Browse Beauty</a>
                    </div>
                </div>
            </div>

            <!-- Category 7: Toys & Games -->
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <span class="badge bg-primary mb-2">20 Products</span>
                        <h4 class="card-title">Toys & Games</h4>
                        <p class="card-text text-muted">Fun for kids and family entertainment</p>
                        <a href="categories.html?category=toys" class="btn btn-outline-primary">Browse Toys</a>
                    </div>
                </div>
            </div>

            <!-- Category 8: Automotive -->
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <span class="badge bg-dark mb-2">9 Products</span>
                        <h4 class="card-title">Automotive</h4>
                        <p class="card-text text-muted">Car accessories and maintenance tools</p>
                        <a href="categories.html?category=automotive" class="btn btn-outline-dark">Browse Automotive</a>
                    </div>
                </div>
            </div>

            <!-- Category 9: Pet Supplies -->
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <span class="badge bg-warning mb-2">11 Products</span>
                        <h4 class="card-title">Pet Supplies</h4>
                        <p class="card-text text-muted">Food, toys and accessories for pets</p>
                        <a href="categories.html?category=pets" class="btn btn-outline-warning">Browse Pet Supplies</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

