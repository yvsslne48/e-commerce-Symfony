{% extends 'base.html.twig' %}

{% block title %}Home - Our Store{% endblock %}
{% block nav_home %}active{% endblock %}

{% block body %}
<div class="bg-primary bg-gradient text-white py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-3 fw-bold mb-4">Welcome to Our Store</h1>
                <p class="lead mb-4">Discover amazing products across all categories.</p>
                <a href="{{ path('app_browse_categories') }}" class="btn btn-light btn-lg me-2">Shop Now</a>
                <a href="{{ path('app_browse_categories') }}" class="btn btn-outline-light btn-lg">Browse Categories</a>
            </div>
        </div>
    </div>
</div>

<div class="container my-5">
    <div class="text-center mb-5">
        <h2 class="display-5 fw-bold">Shop by Category</h2>
        <p class="text-muted">Explore our wide range of products organized by category</p>
    </div>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        <div class="col"><div class="card h-100 shadow-sm"><div class="card-body text-center">
            <span class="badge bg-primary mb-2">Electronics</span>
            <h4 class="card-title">Electronics</h4>
            <p class="card-text text-muted">Headphones, speakers, gadgets and more</p>
            <a href="{{ path('app_products_by_category', {id: 19}) }}" class="btn btn-outline-primary">Browse</a>
        </div></div></div>
        <div class="col"><div class="card h-100 shadow-sm"><div class="card-body text-center">
            <span class="badge bg-warning mb-2">Fashion</span>
            <h4 class="card-title">Fashion</h4>
            <p class="card-text text-muted">Clothing, accessories and footwear</p>
            <a href="{{ path('app_products_by_category', {id: 20}) }}" class="btn btn-outline-warning">Browse</a>
        </div></div></div>
        <div class="col"><div class="card h-100 shadow-sm"><div class="card-body text-center">
            <span class="badge bg-success mb-2">Home & Garden</span>
            <h4 class="card-title">Home &amp; Garden</h4>
            <p class="card-text text-muted">Furniture, decor and gardening tools</p>
            <a href="{{ path('app_products_by_category', {id: 21}) }}" class="btn btn-outline-success">Browse</a>
        </div></div></div>
        <div class="col"><div class="card h-100 shadow-sm"><div class="card-body text-center">
            <span class="badge bg-info mb-2">Sports</span>
            <h4 class="card-title">Sports &amp; Fitness</h4>
            <p class="card-text text-muted">Workout gear, yoga mats and equipment</p>
            <a href="{{ path('app_products_by_category', {id: 22}) }}" class="btn btn-outline-info">Browse</a>
        </div></div></div>
        <div class="col"><div class="card h-100 shadow-sm"><div class="card-body text-center">
            <span class="badge bg-danger mb-2">Books</span>
            <h4 class="card-title">Books</h4>
            <p class="card-text text-muted">Fiction, non-fiction and educational</p>
            <a href="{{ path('app_products_by_category', {id: 23}) }}" class="btn btn-outline-danger">Browse</a>
        </div></div></div>
        <div class="col"><div class="card h-100 shadow-sm"><div class="card-body text-center">
            <span class="badge bg-secondary mb-2">Beauty</span>
            <h4 class="card-title">Beauty &amp; Health</h4>
            <p class="card-text text-muted">Skincare, cosmetics and wellness</p>
            <a href="{{ path('app_products_by_category', {id: 24}) }}" class="btn btn-outline-secondary">Browse</a>
        </div></div></div>
    </div>
</div>
{% endblock %}
